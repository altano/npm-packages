{
  "name": "@altano/npm-packages",
  "version": "0.0.0",
  "private": true,
  "description": "A collection of npm packages maintained by Alan Norbauer",
  "repository": {
    "type": "git",
    "url": "https://github.com/altano/npm-packages.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build build:documentation",
    "changeset": "changeset",
    "check:dependencies": "syncpack lint",
    "check:dependencies:fix": "syncpack fix",
    "check:dependency-resolution": "pnpm install --resolution-only --no-frozen-lockfile",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "format": "turbo run format",
    "preinstall": "npx only-allow pnpm",
    "install:playwright": "playwright install --with-deps",
    "lint": "eslint .github/**/*.yml && eslint --no-warn-ignored --no-error-on-unmatched-pattern *.json *.ts *.yaml",
    "lint:inspect": "pnpm dlx @eslint/config-inspector@latest",
    "prep": "turbo run build build:documentation test lint format check --summarize",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "update": "pnpm update --latest --interactive",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@altano/eslint-config": "workspace:*",
    "@altano/tsconfig": "workspace:*",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "semver": "7.7.4",
    "syncpack": "^14.2.1",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "yaml": "^2.8.3"
  },
  "packageManager": "pnpm@10.32.1"
}
