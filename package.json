{
  "name": "@altano/npm-packages",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/altano/npm-packages.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check:dependencies": "syncpack lint",
    "check:dependencies:fix": "syncpack fix-mismatches",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "format": "turbo run format",
    "install:playwright": "playwright install --with-deps",
    "lint": "eslint --no-error-on-unmatched-pattern *.json *.ts",
    "lint:inspect": "pnpm dlx @eslint/config-inspector@latest",
    "preinstall": "npx only-allow pnpm",
    "prep": "turbo run build test lint format check --summarize",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "update": "pnpm update --latest --interactive",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@altano/tsconfig": "workspace:^",
    "@changesets/cli": "^2.27.1",
    "@swc/core": "^1.7.26",
    "eslint": "^8.57.0",
    "@altano/eslint-config": "workspace:*",
    "eslint-plugin-package-json": "0.15.3",
    "jsonc-eslint-parser": "^2.4.0",
    "oxc-transform": "^0.29.0",
    "prettier": "^3.2.5",
    "tsup": "^8.2.4",
    "turbo": "^1.13.0",
    "typescript": "^5.6.2",
    "unplugin-isolated-decl": "^0.6.3",
    "yaml": "2.4.2"
  },
  "packageManager": "pnpm@10.6.3",
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "x64"
      ]
    }
  }
}
