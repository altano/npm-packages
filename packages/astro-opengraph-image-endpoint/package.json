{
  "name": "@altano/astro-opengraph-image-endpoint",
  "version": "0.0.1-alpha.1",
  "description": "Render Open Graph Images from Astro Components",
  "keywords": [
    "astro",
    "astro-integration",
    "opengraph"
  ],
  "homepage": "https://github.com/altano/npm-packages/tree/main/packages/astro-opengraph-image-endpoint",
  "repository": {
    "type": "git",
    "url": "https://github.com/altano/npm-packages",
    "directory": "packages/astro-opengraph-image-endpoint"
  },
  "license": "ISC",
  "author": {
    "name": "Alan Norbauer",
    "email": "altano@gmail.com",
    "url": "https://alan.norbauer.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./components/meta.astro": "./components/meta.astro",
    "./endpoint-html": "./dist/endpoint-html.js",
    "./endpoint-image": "./dist/endpoint-image.js"
  },
  "files": [
    "components",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "build:types": "tsc --project tsconfig.declarations.json",
    "check:types:src": "tsc --noEmit",
    "check:types:test": "tsc --noEmit --project ./tests/tsconfig.json",
    "clean": "rm -rf .turbo && rm -rf .tsbuildinfo && rm -rf node_modules && rm -rf dist",
    "dev": "tsup --watch",
    "format": "prettier --write src",
    "lint": "eslint src/**/*.ts*",
    "lint:fix": "TIMING=1 eslint src/**/*.ts* --fix",
    "lint:timing": "TIMING=1 eslint src/**/*.ts*",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "he": "^1.2.0",
    "mime-types": "^2.1.35",
    "satori": "^0.10.13",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@altano/assets": "workspace:*",
    "@altano/build-config": "workspace:*",
    "@altano/testing": "workspace:*",
    "@altano/tsconfig": "workspace:*",
    "@altano/vitest-plugins": "workspace:*",
    "@fontsource-variable/inter": "^5.0.17",
    "@inox-tools/astro-tests": "0.5.0",
    "@types/he": "^1.2.3",
    "@types/jest-image-snapshot": "^6.4.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "astro": "^5.4.0",
    "jest-image-snapshot": "^6.4.0",
    "sharp": "^0.33.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.2",
    "utility-types": "^3.10.0",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "astro": "5.x.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
