{
  "name": "@altano/use-element-observer",
  "version": "3.0.0",
  "description": "Intersection-Observer-based Scroll Spy React Hook",
  "homepage": "https://github.com/altano/npm-packages/tree/main/packages/use-element-observer",
  "repository": {
    "type": "git",
    "url": "https://github.com/altano/npm-packages",
    "directory": "packages/use-element-observer"
  },
  "license": "ISC",
  "author": {
    "name": "Alan Norbauer",
    "email": "altano@gmail.com",
    "url": "https://alan.norbauer.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "run-p build:*",
    "build:dts:manual-oxc": "node ./scripts/build-types.js",
    "build:dts:manual-oxc-rollup": "node ./scripts/build-types.js --bundle",
    "build:dts:tsc": "tsc --noCheck",
    "build:tsup:oxc-and-rollup-dts": "tsup --config build-config/tsup.config.browser.ts --out-dir dist/tsup-oxc-rollup",
    "build:rolldown": "rolldown -c rolldown.config.js",
    "build:rollup": "rollup -c rollup.config.js",
    "build:mako": "mako build",
    "build:farm": "echo disabled b/c of https://github.com/farm-fe/farm/issues/1783 // farm build",
    "build:rsbuild": "rsbuild build",
    "build:rslib": "rslib build",
    "check:exports": "attw --pack . --profile esm-only --quiet",
    "check:types:src": "tsc --noEmit",
    "check:types:test": "tsc --noEmit --project ./tests/tsconfig.json",
    "check:unused-dependencies": "depcheck",
    "clean": "rm -rf .turbo && rm -rf .tsbuildinfo && rm -rf node_modules && rm -rf dist",
    "dev": "pnpm run build --watch",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "lint": "eslint",
    "lint:fix": "TIMING=1 pnpm lint --fix",
    "lint:timing": "TIMING=1 pnpm lint",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@uidotdev/usehooks": "^2.4.1"
  },
  "devDependencies": {
    "@altano/build-config": "workspace:*",
    "@altano/testing": "workspace:*",
    "@altano/tsconfig": "workspace:*",
    "@arethetypeswrong/cli": "^0.15.4",
    "@farmfe/cli": "^1.0.4",
    "@farmfe/core": "^1.3.21",
    "@farmfe/js-plugin-dts": "^0.6.4",
    "@farmfe/plugin-react": "^1.2.2",
    "@microsoft/api-extractor": "^7.47.9",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rsbuild/core": "^1.0.4",
    "@rsbuild/plugin-react": "^1.0.2",
    "@rslib/core": "^0.0.6",
    "@swc/core": "^1.7.26",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@umijs/mako": "^0.8.11",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "fast-glob": "^3.3.2",
    "jsdom": "^24.0.0",
    "magic-string": "^0.30.11",
    "npm-run-all": "^4.1.5",
    "oxc-parser": "^0.29.0",
    "oxc-transform": "^0.29.0",
    "picocolors": "^1.1.0",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-refresh": "^0.14.2",
    "rolldown": "^0.13.2",
    "rollup": "^4.21.3",
    "rollup-plugin-dts": "^6.1.1",
    "rsbuild-plugin-dts": "^0.0.6",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "unplugin-isolated-decl": "^0.6.3",
    "vite": "^5.2.8",
    "vitest": "^1.4.0"
  },
  "peerDependencies": {
    "react": "19.x.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
