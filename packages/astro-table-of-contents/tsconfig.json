{
  "extends": "@altano/tsconfig/node.json",
  "include": ["src", "stories", "*.config.ts"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "jsx": "preserve",
    "types": ["astro/client"],
    "verbatimModuleSyntax": false,
    "noEmit": true,
    /* Can remove these when astrobook supports ts */
    "checkJs": true,
    "isolatedDeclarations": false
  }
}
