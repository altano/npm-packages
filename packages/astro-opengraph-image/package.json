{
  "name": "@altano/astro-opengraph-image",
  "version": "0.0.1-alpha.5",
  "description": "Render Open Graph Images from Astro Components",
  "keywords": [
    "astro",
    "withastro",
    "middleware",
    "astro-integration"
  ],
  "homepage": "https://github.com/altano/npm-packages/tree/main/packages/astro-opengraph-image",
  "repository": {
    "type": "git",
    "url": "https://github.com/altano/npm-packages",
    "directory": "packages/astro-opengraph-image"
  },
  "license": "ISC",
  "author": {
    "name": "Alan Norbauer",
    "email": "altano@gmail.com",
    "url": "https://alan.norbauer.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./components/meta.astro": "./components/meta.astro",
    "./middleware": "./dist/middleware.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "components",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsup --config build-config/tsup.config.astro-middleware.ts",
    "build:types": "tsc --project tsconfig.declarations.json",
    "check:types:src": "tsc --noEmit",
    "check:types:test": "tsc --noEmit --project ./tests/tsconfig.json",
    "clean": "rm -rf .turbo && rm -rf .tsbuildinfo && rm -rf node_modules && rm -rf dist",
    "dev": "tsup --watch",
    "format": "prettier --write src",
    "lint": "eslint src/**/*.ts*",
    "lint:fix": "TIMING=1 eslint src/**/*.ts* --fix",
    "lint:timing": "TIMING=1 eslint src/**/*.ts*",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@altano/astro-html-to-image": "workspace:*"
  },
  "devDependencies": {
    "@altano/assets": "workspace:*",
    "@altano/build-config": "workspace:*",
    "@altano/testing": "workspace:*",
    "@altano/tsconfig": "workspace:*",
    "@altano/vitest-plugins": "workspace:*",
    "@types/jest-image-snapshot": "^6.4.0",
    "@vitest/coverage-v8": "^3.0.8",
    "astro": "^4.5.5",
    "jest-image-snapshot": "^6.4.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.2",
    "utility-types": "^3.10.0",
    "vite": "^5.4.11",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "astro": "4.x.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
